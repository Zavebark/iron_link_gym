<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" style="-fx-padding: 15px;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.iron_link_gym.controller.MemberController">

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search by name or phone..." prefWidth="280"/>
        <Button text="Search"        onAction="#handleSearch"  style="-fx-pref-width:80px;"/>
        <Button text="Show All"      onAction="#handleShowAll" style="-fx-pref-width:80px;"/>
        <Separator orientation="VERTICAL"/>
        <Button text="➕ Add"    onAction="#handleAdd"    style="-fx-pref-width:75px;"/>
        <Button text="✏ Edit"   onAction="#handleEdit"   style="-fx-pref-width:75px;"/>
        <Button text="🗑 Delete" onAction="#handleDelete" style="-fx-pref-width:90px;"/>
    </HBox>

    <TableView fx:id="memberTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"      text="ID"            prefWidth="50"/>
            <TableColumn fx:id="colName"    text="Name"          prefWidth="170"/>
            <TableColumn fx:id="colPhone"   text="Phone"         prefWidth="115"/>
            <TableColumn fx:id="colEmail"   text="Email"         prefWidth="170"/>
            <TableColumn fx:id="colJoined"  text="Date Joined"   prefWidth="100"/>
            <TableColumn fx:id="colNotes"   text="Medical Notes" prefWidth="180"/>
        </columns>
        <placeholder><Label text="No members found."/></placeholder>
    </TableView>

    <Label fx:id="statusLabel" text="" style="-fx-text-fill:#555;"/>

</VBox>
