<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.iron_link_gym.controller.MainController"
            prefWidth="1000" prefHeight="650">

    <top>
        <Label text="🏋 Iron-Link Gym Management System"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-padding: 15px;"/>
    </top>

    <center>
        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab text="Members"     fx:id="membersTab"/>
                <Tab text="Plans"       fx:id="plansTab"/>
                <Tab text="Memberships" fx:id="membershipsTab"/>
                <Tab text="Attendance"  fx:id="attendanceTab"/>
            </tabs>
        </TabPane>
    </center>

</BorderPane>